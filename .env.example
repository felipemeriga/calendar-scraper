# Server Configuration
HOST=127.0.0.1
PORT=8080

# API Token for authentication
# Generate a secure random token for production
API_TOKEN=your-secure-api-token-here

# Path to calendars configuration file
# Defaults to "calendars.toml" if not set
CALENDARS_CONFIG=calendars.toml

# Optional: Default ICS Calendar URL (can be overridden via API parameter)
# ICS_URL=https://example.com/calendar.ics
